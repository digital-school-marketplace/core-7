{% extends 'base.html.twig' %}
{% block title %}Browse Listings — Markét{% endblock %}

{% block body %}
    <div class="page">
        {% for message in app.flashes('success') %}
            <div class="flash flash-success">{{ message }}</div>
        {% endfor %}

        <div class="page-header">
            <h1>Browse listings</h1>
            {% if app.user %}
                <a href="{{ path('listing_new') }}" class="btn btn-primary">+ New listing</a>
            {% endif %}
        </div>

        {# Filter bar #}
        <form method="get"
              style="background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem; margin-bottom: 1.75rem; display: flex; gap: 1rem; flex-wrap: wrap; align-items: flex-end;">
            <div style="flex: 1; min-width: 140px;">
                <label
                    style="display:block; font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.07em; color: var(--text-muted); margin-bottom: 0.4rem;">Category</label>
                <select name="category" style="width:100%;">
                    <option value="">All categories</option>
                    {% for category in categories %}
                        <option value="{{ category.id }}" {{ filters.category == category.id ? 'selected' : '' }}>
                            {{ category.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div style="flex: 1; min-width: 100px;">
                <label
                    style="display:block; font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.07em; color: var(--text-muted); margin-bottom: 0.4rem;">Min
                    price</label>
                <input type="number" name="min_price" value="{{ filters.min_price }}" placeholder="€0" min="0"
                       step="0.01">
            </div>
            <div style="flex: 1; min-width: 100px;">
                <label
                    style="display:block; font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.07em; color: var(--text-muted); margin-bottom: 0.4rem;">Max
                    price</label>
                <input type="number" name="max_price" value="{{ filters.max_price }}" placeholder="€999" min="0"
                       step="0.01">
            </div>
            <div style="flex: 1; min-width: 130px;">
                <label
                    style="display:block; font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.07em; color: var(--text-muted); margin-bottom: 0.4rem;">Sort
                    by</label>
                <select name="sort" style="width:100%;">
                    <option value="newest"     {{ filters.sort == 'newest'     ? 'selected' : '' }}>Newest first</option>
                    <option value="oldest"     {{ filters.sort == 'oldest'     ? 'selected' : '' }}>Oldest first</option>
                    <option value="price_asc"  {{ filters.sort == 'price_asc'  ? 'selected' : '' }}>Price: low to high</option>
                    <option value="price_desc" {{ filters.sort == 'price_desc' ? 'selected' : '' }}>Price: high to low</option>
                </select>
            </div>
            <div style="display: flex; gap: 0.5rem; align-items: flex-end;">
                <button type="submit" class="btn btn-primary">Filter</button>
                <a href="{{ path('listing_index') }}" class="btn btn-secondary">Reset</a>
            </div>
        </form>

        {% if listings|length > 0 %}
            <div class="listings-grid">
                {% for listing in listings %}
                    <a href="{{ path('listing_show', { id: listing.id }) }}" class="listing-card">
                        {% if listing.category %}
                            <span class="listing-card-category">{{ listing.category.name }}</span>
                        {% endif %}
                        <div class="listing-card-title">{{ listing.name }}</div>
                        <div class="listing-card-desc">{{ listing.description|slice(0, 110) }}{% if listing.description|length > 110 %}…{% endif %}</div>
                        <div class="listing-card-footer">
                            <span class="listing-card-price">€{{ listing.price }}</span>
                            <span style="display:flex; gap: 0.75rem; align-items:center;">
                                {% set avg = listing.user ? listing.user.averageRating ?? 0 : 0 %}
                                {% if avg %}
                                    <span style="font-size: 0.8rem; color: var(--text-muted);">⭐ {{ avg }}</span>
                                {% endif %}
                                <span class="listing-card-user">{{ listing.user ? listing.user.email : 'Deleted user' }}</span>
                            </span>
                        </div>
                    </a>
                {% endfor %}
            </div>

            <div style="display: flex; justify-content: center; gap: 0.5rem; margin-top: 2rem;">
                {% if currentPage > 1 %}
                    <a href="{{ path('listing_index', filters|merge({'page': currentPage - 1})) }}" class="btn btn-secondary">← Prev</a>
                {% endif %}

                <span style="display: flex; align-items: center; padding: 0 1rem; color: var(--text-muted);">
                    Page {{ currentPage }}
                </span>

                {% if listings|length >= 20 %}
                    <a href="{{ path('listing_index', filters|merge({'page': currentPage + 1})) }}" class="btn btn-secondary">Next →</a>
                {% endif %}
            </div>
        {% else %}
            <div class="empty">
                <div class="empty-icon">🛍️</div>
                <p>No listings match your filters.</p>
                <a href="{{ path('listing_index') }}" class="btn btn-secondary">Clear filters</a>
            </div>
        {% endif %}
    </div>
{% endblock %}
