{% extends 'base.html.twig' %}

{% block body %}
    <h1>{{ listing.name }}</h1>

    <p>{{ listing.description }}</p>
    <p>${{ listing.price }}</p>
    <p>{{ listing.category ? listing.category.name : 'Uncategorised' }}</p>
    <p>Listed by: {{ listing.user.email }}</p>

    <a href="{{ path('listing_edit', { id: listing.id }) }}">Edit</a>

    <form method="post" action="{{ path('listing_delete', { id: listing.id }) }}">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ listing.id) }}">
        <button type="submit" onclick="return confirm('Are you sure?')">Delete</button>
    </form>

    <a href="{{ path('listing_index') }}">Back to listings</a>
{% endblock %}
