{% extends 'base.html.twig' %}
{% block title %}{{ listing.name }} — SchoolMarkét{% endblock %}

{% block body %}
    <div class="page-sm">
        {% for message in app.flashes('success') %}
            <div class="flash flash-success">{{ message }}</div>
        {% endfor %}

        <a href="{{ path('listing_index') }}" class="btn btn-ghost" style="margin-bottom: 1.25rem;">← Back to
            listings</a>

        <div class="card">
            {% if listing.category %}
                <span class="badge">{{ listing.category.name }}</span>
            {% endif %}

            <h1 style="margin-top: 0.75rem; margin-bottom: 0;">{{ listing.name }}</h1>
            <div class="detail-price">€{{ listing.price }}</div>

            <p style="color: var(--text-muted); line-height: 1.75;">{{ listing.description }}</p>

            <hr class="divider">

            <p style="font-size: 0.85rem; color: var(--text-faint);">
                Listed by <a href="{{ listing.user ? path('user_show', { id: listing.user.id }) : '#' }}">
                    <strong
                        style="color: var(--text-muted);">{{ listing.user ? listing.user.email : 'Deleted user' }}</strong>
                </a>
            </p>

            {% if app.user and listing.user != null and app.user.id == listing.user.id %}
                <div class="btn-row">
                    <a href="{{ path('listing_edit', { id: listing.id }) }}" class="btn btn-secondary">Edit listing</a>
                    <form method="post" action="{{ path('listing_delete', { id: listing.id }) }}" style="margin: 0;">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ listing.id) }}">
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Delete this listing?')">
                            Delete
                        </button>
                    </form>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
