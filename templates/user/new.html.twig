{% extends 'base.html.twig' %}

{% block body %}
    <h1>New User</h1>
    {{ form_start(form) }}
    {{ form_errors(form) }}
    {{ form_row(form.email) }}
    {{ form_row(form.plainPassword) }}
    <button type="submit">Create User</button>
    {{ form_end(form) }}
    <a href="{{ path('user_index') }}">Cancel</a>
{% endblock %}
