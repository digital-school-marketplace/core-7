{% extends 'base.html.twig' %}
{% block title %}Log in — SchoolMarkét{% endblock %}

{% block body %}
    <div class="page-sm">
        <div style="text-align: center; margin-bottom: 2rem; margin-top: 1rem;">
            <a href="{{ path('listing_index') }}" style="font-family: var(--font-display); font-weight: 900; font-size: 2rem; color: var(--primary); text-decoration: none; letter-spacing: -0.03em;">SchoolMarkét</a>
            <p style="color: var(--text-muted); margin-top: 0.5rem; font-size: 0.95rem;">Welcome back — log in to your account</p>
        </div>

        {% if error %}
            <div class="flash flash-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <div class="card">
            <form method="post" action="{{ path('app_login') }}">
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" value="{{ last_username }}" required autofocus>
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" required>
                </div>
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center; padding: 0.8rem;">Log in</button>
            </form>
        </div>

        <p style="text-align: center; margin-top: 1.25rem; font-size: 0.875rem; color: var(--text-muted);">
            Don't have an account? <a href="{{ path('user_new') }}" style="color: var(--primary); font-weight: 600;">Sign up</a>
        </p>
    </div>
{% endblock %}
