<!DOCTYPE html>
<html>
<head>
    <title>Current Listings</title>
</head>
<body>
<h1>Listing Details</h1>

{# Listing info dynamically loaded into template #}
<div class="listing">
    <p><strong>Item:</strong> {{ listing.item }}</p>
    <p><strong>Condition:</strong> {{ listing.condition }}</p>
    <p><strong>Price:</strong> ${{ listing.price }}</p>
    <p><strong>Seller:</strong> {{ listing.seller }}</p>
    <p><strong>Date Listed:</strong> {{ listing.date }}</p>
</div>

{# Link back to all listings #}
<a href="{{ path('listings_current') }}">Back to all listings</a>
</body>
</html>

