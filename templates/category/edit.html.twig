{% extends 'base.html.twig' %}
{% block title %}Edit {{ category.name }} — SchoolMarket{% endblock %}

{% block body %}
    <div class="page-sm">
        <a href="{{ path('category_show', { id: category.id }) }}" class="btn btn-ghost" style="margin-bottom: 1.25rem;">← Back</a>
        <h1 style="margin-bottom: 1.5rem;">Edit category</h1>

        <div class="card">
            {{ form_start(form) }}
            {{ form_errors(form) }}
            <div class="form-group">
                {{ form_label(form.name) }}
                {{ form_widget(form.name) }}
                <div class="form-error">{{ form_errors(form.name) }}</div>
            </div>
            <div class="btn-row">
                <button type="submit" class="btn btn-primary">Save changes</button>
                <a href="{{ path('category_show', { id: category.id }) }}" class="btn btn-ghost">Cancel</a>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
