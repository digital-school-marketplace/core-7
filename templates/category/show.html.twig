{% extends 'base.html.twig' %}

{% block body %}
    <h1>{{ category.name }}</h1>

    <p>{{ category.listings|length }} listing(s) in this category</p>

    {% for listing in category.listings %}
        <div>
            <a href="{{ path('listing_show', { id: listing.id }) }}">{{ listing.name }}</a>
            — ${{ listing.price }}
        </div>
    {% else %}
        <p>No listings in this category yet.</p>
    {% endfor %}

    <a href="{{ path('category_edit', { id: category.id }) }}">Edit</a>

    <form method="post" action="{{ path('category_delete', { id: category.id }) }}">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
        <button type="submit" onclick="return confirm('Delete this category?')">Delete</button>
    </form>

    <a href="{{ path('category_index') }}">Back to categories</a>
{% endblock %}
