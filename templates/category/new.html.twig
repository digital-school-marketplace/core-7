{% extends 'base.html.twig' %}

{% block body %}
    <h1>New Category</h1>

    {{ form_start(form) }}
    {{ form_errors(form) }}
    {{ form_row(form.name) }}
    <button type="submit">Create Category</button>
    {{ form_end(form) }}

    <a href="{{ path('category_index') }}">Cancel</a>
{% endblock %}
