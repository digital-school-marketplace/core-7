{% extends 'base.html.twig' %}
{% block title %}Categories — SchoolMarket{% endblock %}

{% block body %}
    <div class="page">
        {% for message in app.flashes('success') %}
            <div class="flash flash-success">{{ message }}</div>
        {% endfor %}

        <div class="page-header">
            <h1>Categories</h1>
            <a href="{{ path('category_new') }}" class="btn btn-primary">+ New category</a>
        </div>

        {% if categories|length > 0 %}
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.25rem;">
                {% for category in categories %}
                    <div class="card" style="border-radius: var(--radius-lg); display: flex; flex-direction: column; gap: 0.75rem;">
                        <div style="display: flex; align-items: center; justify-content: space-between;">
                            <a href="{{ path('category_show', { id: category.id }) }}" style="font-family: var(--font-display); font-weight: 700; font-size: 1.15rem; letter-spacing: -0.02em; color: var(--text); text-decoration: none;">
                                {{ category.name }}
                            </a>
                            <span class="badge">{{ category.listings|length }}</span>
                        </div>
                        <p style="font-size: 0.85rem; color: var(--text-muted);">
                            {{ category.listings|length }} listing{{ category.listings|length != 1 ? 's' : '' }}
                        </p>
                        <div style="display: flex; gap: 0.5rem; margin-top: auto; padding-top: 0.75rem; border-top: 1px solid var(--border);">
                            <a href="{{ path('category_show', { id: category.id }) }}" class="btn btn-secondary" style="padding: 0.4rem 0.85rem; flex: 1; justify-content: center;">View</a>
                            <a href="{{ path('category_edit', { id: category.id }) }}" class="btn btn-ghost" style="padding: 0.4rem 0.85rem;">Edit</a>
                            <form method="post" action="{{ path('category_delete', { id: category.id }) }}" style="margin: 0;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
                                <button type="submit" class="btn btn-danger" style="padding: 0.4rem 0.85rem;" onclick="return confirm('Delete this category?')">Delete</button>
                            </form>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="empty">
                <div class="empty-icon">🏷️</div>
                <p>No categories yet.</p>
                <a href="{{ path('category_new') }}" class="btn btn-primary">Create the first one</a>
            </div>
        {% endif %}
    </div>
{% endblock %}
